# Copy to .env and fill in values. Never commit .env.

# Database (PostgreSQL / RDS)
DATABASE_URL=postgresql://forge:forge@localhost:5432/forgecard

# AWS (use LocalStack endpoints for local dev)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# LocalStack: http://localhost:4566
AWS_ENDPOINT_URL=

# S3 (raw assets + generated exports)
S3_BUCKET_ASSETS=forgecard-assets
S3_BUCKET_EXPORTS=forgecard-exports

# SQS (PDF / export jobs)
SQS_QUEUE_URL=http://localhost:4566/000000000000/forgecard-pdf-generation

# Auth
JWT_SECRET=change-me-in-production-use-long-random-string

# API
PORT=3001
NODE_ENV=development
