generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Auth: unique `username` stores normalized email; password optional for Google-only accounts.
model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique
  passwordHash String?  @map("password_hash")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  projects Project[]
}

/// Optional CSV dataset: { "headers": string[], "rows": Record<string,string>[] }
model Project {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  csvData   Json?    @map("csv_data")
  /// Published CSV URL (e.g. Google Sheets) for server-side refresh
  csvSourceUrl String? @map("csv_source_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  layouts     Layout[]
  assets      Asset[]
  cardGroups  CardGroup[]
}

/// Manual deck slice: name, template layout, and optional published-CSV source for previews.
model CardGroup {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  name           String
  layoutId       String?  @map("layout_id") @db.Uuid
  sortOrder      Int      @default(0) @map("sort_order")
  csvSourceUrl   String?  @map("csv_source_url")
  /// Display label (e.g. Google Sheet tab name) parsed from export filename when available
  dataSourceLabel String? @map("data_source_label")
  csvData        Json?    @map("csv_data")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  layout  Layout? @relation(fields: [layoutId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([projectId, sortOrder])
}

/// react-konva stage JSON + metadata.
model Layout {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  name        String
  lastUpdated DateTime @default(now()) @map("last_updated")
  state       Json

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cardGroups  CardGroup[]

  @@index([projectId])
  @@index([lastUpdated])
}

/// art_key -> S3 location; layouts reference keys, not raw paths.
model Asset {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  artKey    String   @map("art_key")
  s3Key     String   @map("s3_key")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, artKey])
  @@index([projectId])
}
